#!/bin/sh

: git ls-remote

#######################################
# git spec
# Globals:
#   SCRIPT
# Arguments:
#  None
#######################################
spec() {
  cat <<EOF
${SCRIPT}
${SCRIPT} [$(magenta "<remote>")|$(magenta "<url>")]

${SCRIPT} - remote default branch from $(magenta "<url>") or $(magenta "<remote>") \
name (default: $(magenta "origin"))
--
h,help    Show help and exit.
EOF
}

#######################################
# git basename
# Arguments:
#  [<remote>|<url>]  remote name or url
#######################################
main() {
  tmp="$(mktemp)"
  git ls-remote --quiet --exit-code "${1:-origin}" >"${tmp}"
  ref="$(awk '/\tHEAD$/ { print $1 }' "${tmp}")"
  awk -F '/' "/^${ref}\t/ && !/\tHEAD$/ { print \$3 }" "${tmp}"
}

. git-parse.sh; shift
main "$@"
