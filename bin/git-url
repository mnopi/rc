#!/bin/sh

: git config

#######################################
# git spec
# Globals:
#   SCRIPT
# Arguments:
#  None
#######################################
spec() {
  cat <<EOF
${SCRIPT} [$(blue "ARGUMENT")] [$(blue "FORMAT")]
${SCRIPT} [$(red "<remote>")|$(red "<owner/repo>")|$(red "<url>")] \
[$(red "--file")|$(red "--git")|$(red "--https")|$(red "--pip")|$(red "--raw")|\
$(red "--ssh")|$(red "--web")]
${SCRIPT} $(red "<remote>")
${SCRIPT} $(red "<owner/repo>")
${SCRIPT} $(red "<url>")
${SCRIPT} $(red "<remote>") $(red "--ssh")
${SCRIPT} $(red "<url>") $(red "--raw")
${SCRIPT} $(red "--web") $(red "<owner/repo>")
${SCRIPT} $(red "--pip")
${SCRIPT} $(red "--ssh")

${SCRIPT} - remote from config $(red "<remote>"), $(red "<url>") or \
$(red "<owner/repo>") (default: $(red "origin"))
          Valid $(blue "ARGUMENTS"): $(red "<remote>"), $(red "<url>") or \
$(red "<owner/repo>").
          Only one $(blue "ARGUMENT") and/or one $(blue "FORMAT") can be provided.
          Any $(blue "FORMAT") can be used for $(red "<url>") as $(blue "ARGUMENT").
          Default branch is used for $(red "--raw").
          Use ${SCRIPT} instead of ${GIT_COMMAND} when running outside a git repository \
with an $(blue "ARGUMENT") of type $(red "<owner/repo>") or $(red "<url>").
--
h,help      Show help and exit.
b,ping      Check reachability of url.

 $(blue "FORMATS"):
file!        Local url: i.e.: $(magenta "git+file://<user>/<repo>")
git!         $(red "Default") url, i.e.: $(magenta "https://github.com/<user>/<repo>.git")
https!       HTTPS url, i.e.: $(magenta "git+https://github.com/<user>/<repo>.git")
pip!         PIP url, i.e: $(magenta "git+ssh://git@github.com/<user>/<repo>.git")
raw!         GitHub raw url, i.e: $(magenta "https://raw.githubusercontent.com/<user>/<repo>/<branch>")
ssh!         SSH url, i.e: $(magenta "git@github.com:<user>/<repo>.git")
web!         GitHub web url, i.e.: $(magenta "https://github.com/<user>/<repo>")
EOF
}

#######################################
# format url
# Globals:
#   opt
# Arguments:
#  [<remote>|<owner/repo>|<url>]     remote name, owner/repo or path (default: origin)
#######################################
format() {
  name="$(git-name "$1")"; [ "${name-}" ] || die url repo: "$@"
  owner="$(git-owner "$1")"; [ "${owner-}" ] || die url name: "$@"
  prefix="https://github.com/"
  suffix=".git"
  case "${opt:-git}" in
    --file) prefix="git+file://"; suffix="" ;;
    --git) : ;;
    --https) prefix="git+https://github.com/" ;;
    --pip) prefix="git+ssh://git@github.com/" ;;
    --raw) prefix="https://raw.githubusercontent.com/"; suffix="/$(git-default "$1")" ;;
    --ssh)  prefix="git@github.com:" ;;
    --web) suffix="" ;;
  esac
  echo "${prefix}${owner}/${name}${suffix}"
}

#######################################
# remote url from config
# Arguments:
#  <remote>    remote name (default: origin)
#######################################
url() { git config remote."$1".url || die Invalid Remote: "$1"; }

# TODO: aqui lo dejo probar esto, habría que hacer un checkout default,
#  probar url y seguir con submodule que necesita los git all y clone...
#   copiar de semver el como calcula el tag actual
#   Algo de si valid url, añadir un --ping aqui??? y cambiar el ping a ssh access algo mas genérico
#######################################
# git url
# Globals:
#   opt
#######################################
main() {
  while test $# != 0; do
    case "$1" in
      --) shift; break ;;
      --*) opt="$1"  ;;
    esac
    shift
  done

  argument="${1:-origin}"
  >&2 echo "opt: $opt, argument: $argument"
  if echo "${argument}" | grep -q '/' || [ "${opt-}" ]; then
    format "${argument}"
  else
    git config remote."${argument}".url || die Invalid Remote: "${argument}"
  fi
}

. git-parse.sh
echo "$@"
main "$@"
