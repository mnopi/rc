#!/bin/sh

: git rev-parse

#######################################
# git spec
# Globals:
#   SCRIPT
# Arguments:
#  None
#######################################
spec() {
  cat <<EOF
${SCRIPT}
${SCRIPT} [$(magenta "<path>")]

${SCRIPT} - absolute physical path of dirname if $(magenta "<path>") is a file or for the argument \
(default: $(magenta "cwd"))
--
h,help    Show help and exit.
EOF
}

#######################################
# git dirname
# Arguments:
#  [<path>]     path (default: cwd)
#######################################
main() {
  set -e
  if [ "${1-}" ] && [ -d "${1:-.}" ]; then
    cd "${1:-.}"
  elif [ "${1-}" ]; then
    cd "$(dirname "$1")"
  fi
  pwd -P
}

. git-parse.sh; shift
main "$@"
