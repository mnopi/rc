#!/bin/sh

: git submodule

# TODO: Aqui lo dejo sacar la default branch de remote y pasar los aliases y el git all
#   etc.
#   y el commands.

#######################################
# git spec
# Globals:
#   SCRIPT
# Arguments:
#  None
#######################################
spec() {
  cat <<EOF
${SCRIPT} $(red "<url>") [$(red "<path>")]
${SCRIPT} $(red "<url>")

${SCRIPT} - Add submodule with name from $(red "<url>") basename \
(default: $(red "<name>")).
                    With default remote $(red "branch") and $(red "merge") update strategy.

                    Examples:
                      $ ${SCRIPT} https://github.com/bats-core/bats-core $(green '=>') $(red "bats-core")
                      $ ${SCRIPT} https://github.com/bats-core/bats-core \
$(red "share/bats-core") $(green '=>') $(red "share/bats-core")
--
h,help    Show help and exit.
EOF
}

#######################################
# git submodule add
# Arguments:
#  <url>        remote url
# [<path>]      relative directory including repository name (default: url basename).
#######################################
main() {
  name="$(basename "$1" .git)"
  path="${2:-${name}}"

  git submodule status "${name}" >/dev/null 2>&/dev/null || \
    git submodule add --quiet --name "${name}" --branch "$(git default "$1")" "$1" "${path}"
  # TODO: copiado de bats.bash
  local dir="${1:-PWD}" branch="main" recursive=()
  [ "${dir##*/}" = "bats.bash" ] || { branch=bats.core; recursive=( --recursive ); }
  git submodule --quiet init
  git submodule --quiet update --remote "${recursive[@]}"
  git submodule --quiet foreach "${recursive[@]}" "git checkout --quiet ${branch} && git pull --quiet --force"

}
. git-parse.sh; shift
main "$@"
