#!/bin/sh

: git rev-parse

set -eu

script="$(green "${0##*/}")"

OPTIONS_SPEC="$(cat <<EOF
${script}
${script} [$(magentabold "<path>")]

${script} - Super project repository basename from file or directory $(magentabold "<path>") \
in super project or submodule (default: $(magentabold "cwd"))
--
h,help    Show help and exit.
EOF
)"

eval "$(echo "$OPTIONS_SPEC" | git rev-parse --parseopt -- "$@" || echo exit $?)"
shift

path="$(git ${1:+-C "$(git dirname "$1")"} super)" && basename "${path}"
