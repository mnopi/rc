#!/bin/sh

: git rev-parse

set -eu

spec() {
  script="$(greenbold "${0##*/}")"
  cat <<EOF
${script}
${script} [$(redbold "<path>")]

${script} - Super project repository basename from file or directory $(redbold "<path>") \
in super project or submodule (default: $(redbold "cwd"))
--
h,help    Show help and exit.
EOF
}

main() { path="$(git ${1:+-C "$(git dirname "$1")"} super)" && basename "${path}"; }

eval "$(spec | git rev-parse --parseopt -- "$@" || echo exit $?)"; shift
main "$@"


