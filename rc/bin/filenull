#!/bin/sh

. helper.sh

#######################################
# fail if previous pipe /dev/stdin is empty or file in args is empty, respecting if no new line on stdin
# Arguments:
#   [--quiet]
#   [file]      file from arguments or pipe input
# Examples:
#   [ok] { echo foo; false; } | filenull
#   [ok (no newline)] printf '%s' foo | filenull
#   [fail ()] false | filenull --quiet
#   [fail (Empty)] false | filenull
#   [fail (Empty)] true | filenull
#   [fail (Empty)] echo | filenull
#   [fail] filenull
#   [fail] echo >/tmp/a; filenull --quiet /tmp/a
#   [fail] echo >/tmp/a; filenull /tmp/a --quiet
#   [fail] echo >/tmp/a; filenull /tmp/a
#   [fail] echo foo >/tmp/a; filenull --quiet /tmp/a
#   [fail] echo foo >/tmp/a; filenull /tmp/a --quiet
#   [fail] echo foo >/tmp/a; filenull /tmp/a
#   [fail] printf '%s' foo >/tmp/a; filenull /tmp/a
# Notice:
#   /dev/stdin is not accesible in main and should not be tty otherwise hangs
#   'test -s file' will not fail with an empty line that is why content is checked, i.e: echo > /tmp/file
#######################################
main() {
  test -n "$(cat "${file}")" || die "${0##*/}: Empty: '$*'"
  cat "${file}"
  exit
}

fromman filenull "$@"
parse "$@"

if [ -t 0 ]; then
  for arg; do
    [ ! -f "${arg}" ] || { file="${arg}"; main "$@"; }
  done
  false || die "${0##*/}: File must be provided or be piped from stdin: '$*'"
else
  file="$(mktemp)"
  cp /dev/stdin "${file}"
  main
fi
