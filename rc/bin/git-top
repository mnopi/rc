#!/bin/sh

: git rev-parse

script="$(green "${0##*/}")"

OPTIONS_SPEC="$(cat <<EOF
${script}
${script} [$(magentabold "<path>")]

${script} - Top repository path from file or directory (default: $(magentabold "cwd"))
--
h,help    Show help and exit.
EOF
)"

eval "$(echo "$OPTIONS_SPEC" | git rev-parse --parseopt -- "$@" || echo exit $?)"
shift

git ${1:+-C "$(git dirname "$1")"} rev-parse --show-toplevel
