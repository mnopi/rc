#!/bin/sh

: git rev-parse

set -eu

script="$(green "${0##*/}")"

OPTIONS_SPEC="$(cat <<EOF
${script}
${script} [$(magentabold "<path>")]

${script} - Basename if $(magentabold "<path>") is not a directory (default: $(magentabold "cwd"))
--
h,help    Show help and exit.
EOF
)"

eval "$(echo "$OPTIONS_SPEC" | git rev-parse --parseopt -- "$@" || echo exit $?)"
shift

if [ "${1-}" ] && [ ! -d "${1:-.}" ]; then
  basename "$1"
fi
