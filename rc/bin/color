#!/usr/bin/env bash
# shellcheck disable=SC2016

#
# show colors and helper functions output, or generate color lib

. helper.sh

# Show Test Var 1
#
export VAR1=1
# Show Test Var 2
#
export VAR2=2

#######################################
# actions
# Globals:
#   ACTIONS
#   BIN_TMP_DIR
#   file
#   header
#   if
#   symbol
# Arguments:
#  None
#######################################
action() {
  local file script

  for action in "${!ACTIONS[@]}"; do
      script="${ACTIONS[${action}]}"
      file="${BIN_TMP_DIR}/${action}"
    cat >"${file}" <<EOF
#!/bin/sh

# <html><h2>${action}</h2>
# <h3>Examples</h3>
# <dl>
# <dt>
# Show first argument in Italic and second ${action}, prefixed with ${script} symbol:
# </dt>
# <dd>
# <pre><code class="language-bash">${action} Brew
# </code></pre>
# </dd>
# </dl>
# </html>
ret=\$?
${script} "\${1}:" "${action}"
exit \$ret
EOF
    chmod +x "${file}"
  done
}

#######################################
# generate lib escaped for PS1 and normal
# Globals:
#   BIN_DIR
#   BIN_TMP_DIR
#   BUILD
#   LIB_PATH
#   LIB_TMP_PATH
#   SCRIPT
#   SYM_PATH
#   SYM_TMP_PATH
# Arguments:
#   0
# Escaped:
#   https://github.com/koalaman/shellcheck/wiki/SC2025
#   https://mywiki.wooledge.org/BashFAQ/053
#   Using \[ and \] around colors is necessary to prevent issues with command line editing/browsing/completion!
#   Escaped should not be formatted with "printf '%b'" or "echo -e" and leave it as it is in PS1, so
#   'printf "%s" "\[\e[31m\]"'
#     - Red: '\[\e[31m\]' vs. '\033[31m' or '\e[31m'
#     - Reset: '\[\e[0m\]' or '\[\e(B\e[m\]' vs. '\033[0m' or \e[0m
#   The \[ \] are only special when you assign PS1, if you print them inside a function that runs when the prompt
#   is displayed it doesn't work. In this case you need to use the bytes \001 and \002.
#   prompt() { printf '\001%s\002%s\001%s\002' '\e[33m' message '\e[0m'; }
#   PS1="\$(prompt)\$ "
# Printf:
#   printf '\e[33m%s\e(B\e[m' message
#   printf '\e[33m%s\e[0m' message
#   printf '\033[33m%s\033[0m' message
#   printf '%b' '\e[33m'; printf '%b' message; printf '%b' '\e(B\e[m'
#   printf '%b' '\e[33m'; printf '%b' message; printf '%b' '\e[0m'
#   printf '%b' '\033[33m'; printf '%b' message; printf '%b' '\033[0m'
#######################################
build() {
  local super
  super="$(git super "$0")"
  BUILD=true
  BIN_TMP_DIR="$(mktemp -d)"
  LIB_TMP_PATH="$(mktemp)"
  SYM_TMP_PATH="$(mktemp)"
  set -eu
  cd "${super}"
  realpath "$0" | grep -q "^${super}" || die Can Only Run from RC Repo
  mkdir -p "${BIN_DIR}"

  cat >"${LIB_TMP_PATH}" <<EOF
# shellcheck shell=sh

#
# Colors library (generated by: ${SCRIPT})

EOF

  colors
  ps2
  symbol
  action
  cmp Bin "${BIN_TMP_DIR}" "${BIN_DIR}"
  cmp Lib "${LIB_TMP_PATH}" "${LIB_PATH}"
  cmp Symbol "${SYM_TMP_PATH}" "${SYM_PATH}"
}

#######################################
# compares if changes and copy
# Globals:
#   SCRIPT
# Arguments:
#   1     source
#   2     dest
#######################################
cmp() {
  if ! [ -e "$3" ] || ! diff -s "$2" "$3" > /dev/null; then
    show --start "Color $1:" Installing
    if test -f "$3"; then
      cp "$2" "$3"
    else
      rsync -av --delete "$2"/ "$3" >/dev/null
    fi
    git add "$3"
    git commit --quiet -m "${SCRIPT}" "$3"
    git push --quiet
    show --finish "Color $1:" Installed
  fi
}

#######################################
# generate colors array global with escaped for PS1 and normal
# Globals:
#   ACTIONS
#   COLORS
#   ESCAPE
#   RESET
# Arguments:
#   None
# Escaped:
#   https://github.com/koalaman/shellcheck/wiki/SC2025
#   https://mywiki.wooledge.org/BashFAQ/053
#   Using \[ and \] around colors is necessary to prevent issues with command line editing/browsing/completion!
#   Escaped should not be formatted with "printf '%b'" or "echo -e" and leave it as it is in PS1, so
#   'printf "%s" "\[\e[31m\]"'
#     - Red: '\[\e[31m\]' vs. '\033[31m' or '\e[31m'
#     - Reset: '\[\e[0m\]' or '\[\e(B\e[m\]' vs. '\033[0m' or \e[0m
#   The \[ \] are only special when you assign PS1, if you print them inside a function that runs when the prompt
#   is displayed it doesn't work. In this case you need to use the bytes \001 and \002.
#   prompt() { printf '\001%s\002%s\001%s\002' '\e[33m' message '\e[0m'; }
#   PS1="\$(prompt)\$ "
# Printf:
#   printf '\e[33m%s\e(B\e[m' message
#   printf '\e[33m%s\e[0m' message
#   printf '\033[33m%s\033[0m' message
#   printf '%b' '\e[33m'; printf '%b' message; printf '%b' '\e(B\e[m'
#   printf '%b' '\e[33m'; printf '%b' message; printf '%b' '\e[0m'
#   printf '%b' '\033[33m'; printf '%b' message; printf '%b' '\033[0m'
#######################################
colors() {
  local e="\e[" i=0 key suffix="" value
  declare -A formats=(["Normal"]=0 ["Bold"]=1 ["BoldItalic"]="3m${e}1" ["Dim"]=2 ["Italic"]=3 ["Under"]=4 \
                      ["Invert"]=7 ["Strike"]=9)
  ESCAPE="Esc"; RESET="${e}0m"
  declare -Ag ACTIONS=( ["Installing"]="Start" ["Installed"]="Finish")
  declare -Ag COLORS=()

  save Reset "${e}0m"
  save "Reset${ESCAPE}" "\[${COLORS["Reset"]}\]"
  for format in "${!formats[@]}"; do
    # \e[0m
    value="${e}${formats[${format}]}m"
    save "${format}" "${value}"
    ! [[ "${format}" =~ Bold|BoldItalic|Italic|Normal ]] || save "${format}${ESCAPE}" "\[${value}\]"
  done
  for color in Black Red Green Yellow Blue Magenta Cyan Grey; do
    for format in "${!formats[@]}"; do
      suffix=""; [ "${format}" = "Bold" ] || suffix="${format}"
      key="${color}${suffix}"
      value="${e}${formats[${format}]};3${i}m"
      save "${key}" "${value}"
      save "${key}Bg" "${e}${formats[${format}]};4${i}m"
      ! [[ "${format}" =~ Bold|BoldItalic|Italic|Normal ]] || save "${key}${ESCAPE}" "\[${value}\]"
    done
    ((i+=1))
  done
}

#######################################
# show colors and helper functions output
# Globals:
#   COLORS
#   ESCAPE
#   LIB_PATH
#   RESET
#   SYM_PATH
# Arguments:
#   None
#######################################
demo() {
  local action color current normal previous symbol
  colors
  . "${LIB_PATH}"
  . "${SYM_PATH}"
  while read -r color; do
    current="${color:0:3}"; [ "${color:0:5}" != "Green" ] || current="${current}-"
    [ "${current}" = "${previous-}" ] || { [ ! "${previous-}" ] || echo;previous="${current}"; }
    printf "${COLORS[${color/${ESCAPE}/}]}%s${RESET} " "${color}"  # from array
    printf -- "$(eval echo \$"${color/${ESCAPE}/}")%s${Reset} " "${color}"  # from lib
    normal="${color/${ESCAPE}/}"
    ${normal,,} "${color}" # from bin
    echo
  done < <(printf "%s\n" "${!COLORS[@]}" | sort | grep -v Reset)

  echo

  while read -r symbol; do
    printf -- "$(eval echo \$"${symbol}")%s${Reset} " " ${symbol}"
    printf -- "$(eval echo \$"${symbol}")%s${Reset} " " ${symbol}${ESCAPE}"
    ${symbol} "${symbol}"
    ${symbol} "${symbol}:" Argument
    echo
  done < <(awk -F '[= ]' "/export / && ! /${ESCAPE}/{ print \$2 }" "${SYM_PATH}")

  echo

  while read -r action; do
    ${action} Color
    echo
  done < <(printf "%s\n" "${!ACTIONS[@]}" | sort)

  echo

  export VAR1=1 VAR2=2
  DEBUG=1 debug VAR1 2>&1
  debug Debug Message: not shown "DEBUG unset" 2>&1
  DEBUG=1 debug VAR1 VAR2 2>&1
  DEBUG=1 QUIET=1 debug Not Shown: "QUIET=1" 2>&1
  DEBUG=1 debug 2>&1

  echo

  error Error Message 2>&1
  QUIET=1 error Not Shown: "QUIET=1" 2>&1
  error 2>&1

  echo

  success Success Message
  QUIET=1 success Not Shown: "QUIET=1"
  success

  echo

  VERBOSE=1 verbose Verbose Message: "VERBOSE=1"
  VERBOSE=1 QUIET=1 verbose Not Shown: "QUIET=1"
  VERBOSE=1 verbose

  echo

  WARNING=1 warning Warning Message: "WARNING=1" 2>&1
  WARNING=1 QUIET=1 warning Not shown: "QUIET=1" 2>&1
  WARNING=1 warning 2>&1

  echo

  die Die Message
}

#######################################
# update colors in files and COLORS array
# Globals:
#   BIN_TMP_DIR
#   BUILD
#   ESCAPE
#   COLORS
#   LIB_TMP_PATH
# Arguments:
#   1   Color Variable Name
#   2   Color Value
#######################################
save() {
  local lower="${1,,}"
  COLORS["$1"]="$2"
  if $BUILD; then
    local file="${BIN_TMP_DIR}/${lower}"

    tee -a "${LIB_TMP_PATH}" > /dev/null <<EOF
# <html><h2>$1</h2>
# <p><strong><code>\$$1</code></strong> Color $1.</p>
# </html>
export $1="$2"

EOF

    if [[ "$1" =~ ${ESCAPE} ]]; then
      cat > "${file}" <<EOF
#!/bin/sh

# <html><h2>${lower}</h2>
# https://mywiki.wooledge.org/BashFAQ/053
# <a href="https://mywiki.wooledge.org/BashFAQ/053">Dynamic prompt or read -p</a>
# <h3>Examples</h3>
# <dl>
# <dt>Show arguments in $1 escaped for \$PS1,dynamic prompt or read -p:</dt>
# <dd>
# <pre><code class="language-bash">${lower} Show Text
# </code></pre>
# </dd>
# </dl>
# </html>
[ \$# -eq 0 ] || printf -- '%s' "$2" "\$*" "${COLORS["Reset${ESCAPE}"]}"
EOF
    else
      cat > "${file}" <<EOF
#!/bin/sh

# <html><h2>${lower}</h2>
# <h3>Examples</h3>
# <dl>
# <dt>Show arguments with space in $1:</dt>
# <dd>
# <pre><code class="language-bash">${lower} Show Text
# </code></pre>
# </dd>
# </dl>
# </html>
[ \$# -eq 0 ] || printf '%b' "$2"; printf '%b' "\$*"; printf '%b' "${RESET}"
EOF
    fi
    chmod +x "${file}"
  fi
}

#######################################
# save PS2 to profile lib
# Arguments:
#  None
#######################################
ps2() {
  tee -a "${LIB_TMP_PATH}" > /dev/null <<'EOF'
# PS2
#
export PS2="\$(if [ \$(id -u) -eq 0 ]; then printf -- '%s' '${MagentaEsc}' '> ' '${ResetEsc}'; \
else printf -- '%s' '${GreenEsc}' '> ' '${ResetEsc}'; fi)"
EOF
}

#######################################
# add color symbols variables and executables
# Globals:
#   SYM_TMP_PATH
# Arguments:
#   None
#######################################
symbol() {
  local file header="" if="" symbol
  tee -a "${SYM_TMP_PATH}" > /dev/null <<EOF
# shellcheck shell=sh

#
# Color Symbols library (generated by: ${SCRIPT})

# Critical Red Invert "✘"
#
export Critical="${COLORS["RedInvert"]}✘${Reset}"

# Debug Magenta "+"
#
export Debug="${COLORS["Magenta"]}+${Reset}"

# Error Red "✘"
#
export Error="${COLORS["Red"]}✘${Reset}"

# Error Red "✘" Escaped
#
export Error${ESCAPE}="${COLORS["Red${ESCAPE}"]}✘${ResetEsc}"

# Finish Green "=＞"
#
export Finish="=${COLORS["Green"]}＞${Reset}"

# Minus Red "－"
#
export Minus="${COLORS["Red"]}－${Reset}"

# Minus Red "－" Escaped
#
export Minus${ESCAPE}="${COLORS["Red${ESCAPE}"]}－${ResetEsc}"

# More Magenta "＞"
#
export More="${COLORS["Magenta"]}＞${Reset}"

# More Magenta ">" Escaped
#
export More${ESCAPE}="${COLORS["Magenta${ESCAPE}"]}>${ResetEsc}"

# Multiply Blue "×"
#
export Multiply="${COLORS["Blue"]}×${Reset}"

# Multiply Blue "×" Escaped
#
export Multiply${ESCAPE}="${COLORS["Blue${ESCAPE}"]}×${ResetEsc}"

# Notice Cyan "‼"
#
export Notice="${COLORS["Cyan"]}‼${Reset}"

# Notice Cyan "‼" Escaped
#
export Notice${ESCAPE}="${COLORS["Cyan${ESCAPE}"]}‼${ResetEsc}"

# Ok Green "✔"
#
export Ok="${COLORS["Green"]}✔${Reset}"

# Ok Green "✔" Escaped
#
export Ok${ESCAPE}="${COLORS["Green${ESCAPE}"]}✔${ResetEsc}"

# Plus Green "+"
#
export Plus="${COLORS["Green"]}+${Reset}"

# Plus Green "+" Escaped
#
export Plus${ESCAPE}="${COLORS["Green${ESCAPE}"]}+${ResetEsc}"

# Start Blue "=＞"
#
export Start="=${COLORS["Blue"]}＞${Reset}"

# Success Blue "◉" Escaped
#
export Success${ESCAPE}="${COLORS["Blue${ESCAPE}"]}◉${ResetEsc}"

# Success Blue "◉"
#
export Success="${COLORS["Blue"]}◉${Reset}"

# Success Blue "◉" Escaped
#
export Success${ESCAPE}="${COLORS["Blue${ESCAPE}"]}◉${ResetEsc}"

# Tilde Blue "～"
#
export Tilde="${COLORS["Blue"]}～${Reset}"

# Tilde Blue "～" Escaped
#
export Tilde${ESCAPE}="${COLORS["Blue${ESCAPE}"]}～${ResetEsc}"

# Verbose Magenta "＋"
#
export Verbose="${COLORS["Magenta"]}＋${Reset}"

# Verbose Magenta "＋" Escaped
#
export Verbose${ESCAPE}="${COLORS["Magenta${ESCAPE}"]}＋${ResetEsc}"

# Wait Yellow "…"
#
export Wait="${COLORS["Yellow"]}…${Reset}"

# Wait Yellow "…" Escaped
#
export Wait${ESCAPE}="${COLORS["Yellow${ESCAPE}"]}…${ResetEsc}"

# Warning Yellow "！"
#
export Warning="${COLORS["Yellow"]}！${Reset}"

# Warning Yellow "！" Escaped
#
export Warning${ESCAPE}="${COLORS["Yellow${ESCAPE}"]}！${ResetEsc}"
EOF

  . "${SYM_TMP_PATH}"
  while read -r symbol; do
    if [ "${symbol}" = 'Verbose' ]; then
      header="$(cat <<'EOF'
# <html><h2>Dry Run</h2>
# <p><strong><code>$DRY_RUN</code></strong> (Default: 0).</p>
# <p>Activate with either of:</p>
# <ul>
# <li><code>DRY_RUN=1</code></li>
# <li><code>--dryrun</code></li>
# </ul>
# </html>
DRY_RUN="${DRY_RUN:-0}"

# <html><h2>Show Verbose Messages</h2>
# <p><strong><code>$VERBOSE</code></strong>  (Default: 0).</p>
# <p><strong><code>Verbose messages are shown if set to 1.</code></strong></p>
# <p>Activate with either of:</p>
# <ul>
# <li><code>VERBOSE=1</code></li>
# <li><code>--verbose</code></li>
# </ul>
# </html>
VERBOSE="${VERBOSE:-0}"
EOF
)"
      if=' && { [ "${VERBOSE}" -eq 1 ] || [ "${DRY_RUN-}" -eq 1 ]; }'
    fi
    file="${BIN_TMP_DIR}/${symbol}"
    cat > "${file}" <<EOF
#!/bin/sh
${header}
# <html><h2>${symbol}</h2>
# <h3>Examples</h3>
# <dl>
# <dt>
# Show arguments separated with space, prefixed with ${symbol} symbol. If more than one arguments then first in Italic:
# </dt>
# <dd>
# <pre><code class="language-bash">${symbol} Show Text
# </code></pre>
# </dd>
# </dl>
# </html>
ret=\$?

if { [ "\${QUIET-0}" -ne 1 ] && [ "\${QQUIET-0}" -ne 1 ]; }${if}; then
  printf '%b' "$(eval echo \$"${symbol}")"
  [ \$# -ne 0 ] || exit \$ret
  [ \$# -eq 1 ] || { italic " \$1"; shift; }
  printf '%s\n' " \$*"
fi

exit \$ret
EOF
    chmod +x "${file}"
  done < <(awk -F '[= ]' "/export / && ! /${ESCAPE}/{ print \$2 }" "${SYM_TMP_PATH}")

}

#######################################
# show colors and helper functions output, or generate color lib
# Globals:
#   BIN_DIR
#   BUILD
#   LIB_PATH
#   RC
#   RC_PROFILE_D
#   SCRIPT
#   SYM_PATH
# Arguments:
#  None
#######################################
main() {
  local arg func=demo
  BIN_DIR="${RC}/color"
  BUILD=false
  SCRIPT="${0##*/}"
  LIB_PATH="${RC_PROFILE_D}/${SCRIPT}.sh"
  SYM_PATH="${RC_PROFILE_D}/symbol.sh"
  for arg do
    case "${arg}" in
      build) func="${arg}" ;;
      --*) fromman "$0" "$@" || exit 0 ;;
    esac
  done
  ${func}
}

main "$@"
