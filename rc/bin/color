#!/usr/bin/env bash
# bashsupport disable=BP2001,BP2001
# shellcheck disable=SC2016,SC2028,SC2034

#
# show colors and helper functions output, or generate color lib

. helper.sh
. arrays.bash

e="\e["
_SCRIPT="${0##*/}"

# Suffix for BackGround Colors
#
BACKGROUND="Bg"

# Suffix for Escaped Colors
#
ESCAPED="Esc"

# Escaped Colors for PS1
#
ESCAPED_COLORS="Bold|BoldItalic|Italic|Normal"

# Escaped Symbols for PS1
#
ESCAPED_SYMBOLS="Error|Minus|More|Multiply|Notice|Ok|Plus|Success|Tilde|Verbose|Wait|Warning"

# $FORMAT_COLOR_DEFAULT value will not be a suffix in Variables and Scripts (does not apply for Normal Format)
#
FORMAT_COLOR_DEFAULT="Bold"

# White Formats
#
WHITE=""

# Actions Script Names and Second Argument Value
#
declare -Ag ACTIONS=( ["Installing"]="Start" ["Installed"]="Finish")

# Color Names and Values
#
declare -Ag COLORS=()

# Destination Directories and Files
#
declare -Ag DST=( ["bin"]="${RC}/color" ["lib"]="${RC_PROFILE_D}/${_SCRIPT}.sh"
                  ["ps2"]="${RC_PROFILE_D}/ps2.sh" ["sym"]="${RC_PROFILE_D}/symbol.sh")

# First Argument with Different Format: Bin Name and Format
#
declare -Ag FIRST=( ["bin"]="FirstArg"  ["format"]="Italic" )

# Color Formats
#
declare -Ag FORMATS=( ["Normal"]=0 ["Bold"]=1 ["BoldItalic"]="3m${e}1" ["Dim"]=2 ["Italic"]=3 ["Under"]=4
                      ["Invert"]=7 ["Strike"]=9 )

# Color Names
#
declare -ag NAMES=( "Black" "Red" "Green" "Yellow" "Blue" "Magenta" "Cyan" "Grey" )

# Sorted Keys of Associated Arrays
#
declare -Ag SORTED=( ["actions"]="$(printf "%s\n" "${!ACTIONS[@]}" | sort)" ["colors"]="" ["symbols"]="" )

# Symbol Names and Colors
#
declare -Ag SYMBOLS_COLORS=( ["Critical"]="RedInvert" ["Debug"]="Magenta" ["Ellipsis"]="Cyan" ["Error"]="Red"
                             ["Finish"]="Green" ["Minus"]="Red" ["More"]="Magenta" ["Multiply"]="Blue"
                             ["Notice"]="Cyan" ["Ok"]="Green" ["Plus"]="Green" ["Start"]="Blue"
                             ["Success"]="Blue" ["Tilde"]="Blue" ["Verbose"]="Magenta" ["Warning"]="Yellow" )

# Symbol Names and Symbol
#
declare -Ag SYMBOLS_ICON=( ["Critical"]="✘" ["Debug"]="+" ["Ellipsis"]="…" ["Error"]="✘"
                           ["Finish"]="＞" ["Minus"]="+" ["More"]="＞" ["Multiply"]="×"
                           ["Notice"]="‼" ["Ok"]="✔" ["Plus"]="+" ["Start"]="＞"
                           ["Success"]="◉" ["Tilde"]="～" ["Verbose"]="＋" ["Warning"]="！" )

# Symbol Names and Prefix Symbol in Normal
#
declare -Ag SYMBOLS_PREFIX=( ["Finish"]="=" ["Start"]="=")

# Colorized Symbols Names and Values
#
declare -Ag SYMBOLS=()

# Tmp Directories and Files
#
declare -Ag TMP=(["bin"]="$(mktemp -d)" ["lib"]="$(mktemp)" ["ps2"]="$(mktemp)" ["sym"]="$(mktemp)")

#######################################
# generate colors array global with escaped for PS1 and normal
# Globals:
#   ACTIONS
#   COLORS
#   ESCAPE
# Arguments:
#   None
# Escaped:
#   https://github.com/koalaman/shellcheck/wiki/SC2025
#   https://mywiki.wooledge.org/BashFAQ/053
#   Using \[ and \] around colors is necessary to prevent issues with command line editing/browsing/completion!
#   Escaped should not be formatted with "printf '%b'" or "echo -e" and leave it as it is in PS1, so
#   'printf "%s" "\[\e[31m\]"'
#     - Red: '\[\e[31m\]' vs. '\033[31m' or '\e[31m'
#     - Normal: '\[\e[0m\]' or '\[\e(B\e[m\]' vs. '\033[0m' or \e[0m
#   The \[ \] are only special when you assign PS1, if you print them inside a function that runs when the prompt
#   is displayed it doesn't work. In this case you need to use the bytes \001 and \002.
#   prompt() { printf '\001%s\002%s\001%s\002' '\e[33m' message '\e[0m'; }
#   PS1="\$(prompt)\$ "
# Printf:
#   printf '\e[33m%s\e(B\e[m' message
#   printf '\e[33m%s\e[0m' message
#   printf '\033[33m%s\033[0m' message
#   printf '%b' '\e[33m'; printf '%b' message; printf '%b' '\e(B\e[m'
#   printf '%b' '\e[33m'; printf '%b' message; printf '%b' '\e[0m'
#   printf '%b' '\033[33m'; printf '%b' message; printf '%b' '\033[0m'
#######################################
arrays() {
  local color format i=0 key prefix suffix="" symbol value

  for format in "${!FORMATS[@]}"; do
    # \e[0m
    value="${e}${FORMATS["${format}"]}m"
    COLORS["${format}"]="${value}"
    # save "${format}" "${value}"
    ! [[ "${format}" =~ ${ESCAPED_COLORS} ]] || COLORS["${format}${ESCAPED}"]="\[${value}\]"
  done

  for color in "${NAMES[@]}"; do
    for format in "${!FORMATS[@]}"; do
      suffix=""; [ "${format}" = "${FORMAT_COLOR_DEFAULT}" ] || suffix="${format}"
      key="${color}${suffix}"
      value="${e}${FORMATS["${format}"]};3${i}m"
      COLORS["${key}"]="${value}"
      COLORS["${key}${BACKGROUND}"]="${e}${FORMATS["${format}"]};4${i}m"
      # save "${key}" "${value}"
      # save "${key}${BACKGROUND}" "${e}${FORMATS[${format}]};4${i}m"
      ! [[ "${format}" =~ ${ESCAPED_COLORS} ]] || COLORS["${key}${ESCAPED}"]="\[${value}\]"
    done
    ((i+=1))
  done

  WHITE="$(sorted white)"
  SORTED["colors"]="$(sorted)"

  for symbol in "${!SYMBOLS_ICON[@]}"; do
    prefix="$(default "${symbol}" SYMBOLS_PREFIX)"
    value="${prefix}${COLORS["${SYMBOLS_COLORS["${symbol}"]}"]}${SYMBOLS_ICON["${symbol}"]}${COLORS["Normal"]}"
    SYMBOLS["${symbol}"]="${value}"
    ! [[ "${symbol}" =~ ${ESCAPED_SYMBOLS} ]] || SYMBOLS["${symbol}${ESCAPED}"]="\[${value}\]"
  done

  SORTED["symbols"]="$(printf "%s\n" "${!SYMBOLS[@]}" | sort)"
}

#######################################
# generate lib escaped for PS1 and normal
# Globals:
#   BIN_DIR
#   BIN_DIR_TMP
#   BUILD
#   LIB_PATH
#   LIB_PATH_TMP
#   SCRIPT
#   SYM_PATH
#   SYM_PATH_TMP
# Arguments:
#   0
# Escaped:
#   https://github.com/koalaman/shellcheck/wiki/SC2025
#   https://mywiki.wooledge.org/BashFAQ/053
#   Using \[ and \] around colors is necessary to prevent issues with command line editing/browsing/completion!
#   Escaped should not be formatted with "printf '%b'" or "echo -e" and leave it as it is in PS1, so
#   'printf "%s" "\[\e[31m\]"'
#     - Red: '\[\e[31m\]' vs. '\033[31m' or '\e[31m'
#     - Normal: '\[\e[0m\]' or '\[\e(B\e[m\]' vs. '\033[0m' or \e[0m
#   The \[ \] are only special when you assign PS1, if you print them inside a function that runs when the prompt
#   is displayed it doesn't work. In this case you need to use the bytes \001 and \002.
#   prompt() { printf '\001%s\002%s\001%s\002' '\e[33m' message '\e[0m'; }
#   PS1="\$(prompt)\$ "
# Printf:
#   printf '\e[33m%s\e(B\e[m' message
#   printf '\e[33m%s\e[0m' message
#   printf '\033[33m%s\033[0m' message
#   printf '%b' '\e[33m'; printf '%b' message; printf '%b' '\e(B\e[m'
#   printf '%b' '\e[33m'; printf '%b' message; printf '%b' '\e[0m'
#   printf '%b' '\033[33m'; printf '%b' message; printf '%b' '\033[0m'
#######################################
build() {
  local dst changed=false i show=echo tmp super
  super="$(git super "$0")"
  set -eu
  cd "${super}"

  realpath "$0" | grep -q "^${super}" || die Can Only Run from RC Repo
  [ -d "${DST["bin"]}" ] || mkdir -p "${DST["bin"]}"

  cat > "${TMP["lib"]}" <<EOF
# shellcheck shell=sh

#
# Colors library (generated by: ${_SCRIPT})

EOF

  cat > "${TMP["sym"]}" <<EOF
# shellcheck shell=sh

#
# Symbol Colors library (generated by: ${_SCRIPT})

EOF
  eval "$(awk -F '(' '/^save_.*\(/ { print $1 }' "$0")"

  PATH="${TMP["bin"]}:${PATH}"

  for i in bin lib ps2 sym; do
    dst="${DST["${i}"]}" tmp="${TMP["${i}"]}"
      if ! [ -e "${dst}" ] || ! diff -s "${tmp}" "${dst}" >/dev/null; then
        cmd Installing || show="echo"
        ${show:-Installing} "${_SCRIPT^}: ${i}"
        if test -f "${dst}" && filehas "${tmp}" >/dev/null; then
          cp "${tmp}" "${dst}"; changed=true
        elif dirhas "${tmp}" 2>/dev/null; then
          rsync -av --delete "${tmp}"/ "${dst}" >/dev/null; changed=true
        fi
        if $changed; then
          git add "${dst}"
          git commit --quiet -m "${_SCRIPT}" "${dst}"
          git push --quiet
          ${show:-Installed} "${_SCRIPT^}: ${i}"
        fi
      fi
  done
}

#######################################
# show colors and helper functions output
# Globals:
#   COLORS
#   ESCAPE
#   LIB_PATH
#   SYM_PATH
# Arguments:
#   None
#######################################
demo() {
  local action actions array color colors current normal previous script symbol symbols variable

  echo "## LIB"
  for color in ${SORTED[colors]}; do
    current="${color:0:3}"
    if [[ "${color}" =~ ^$(newline-to "${WHITE}" '|^') ]]; then
      current="WHITE-"
    elif [ "${color:0:5}" = "Green" ]; then
      current="${current}-"
    fi
    [ "${current}" = "${previous-}" ] || { [ ! "${previous-}" ] || echo; previous="${current}"; }

    array="$(printf "${COLORS["${color/${ESCAPED}/}"]}%s${COLORS["Normal"]}" "${color}")"  # from array
    variable="$(printf -- "$(eval echo \$"${color/${ESCAPED}/}")%s${Normal}" "${color}")"
    [ "${array}" =  "${variable}" ] || { echo array: "${array}", variable: "${variable}"; exit 1; }

    normal="${color/${ESCAPED}/}"
    script="$(${normal,,} "${color,,}()")"
    [ "${array}" = "$(${normal,,} "${color}")" ] \
      || { echo array: "${array}", script: "$(${normal,,} "${color}")"; exit 1; }

    echo "${array} ${script}"
  done; echo

  ${FIRST["bin"]} "${FIRST["bin"]}():" "${FIRST["format"]}"
  echo

  for symbol in ${SORTED[symbols]}; do
    array="$(printf "${SYMBOLS["${symbol/${ESCAPED}/}"]}%s${COLORS["Normal"]}" " ${symbol}")"
    variable="$(printf -- "$(eval echo \$"${symbol/${ESCAPED}/}")%s${Normal}" " ${symbol}")"
    [ "${array}" =  "${variable}" ] || { echo array: "${array}", variable: "${variable}"; exit 1; }

    if [[ "${symbol}" =~ ${ESCAPED} ]]; then
      printf "%s" "${array}"
    else
      script="$(VERBOSE=1 ${symbol} "${symbol}()")"
      normal="$(VERBOSE=1 ${symbol} "${symbol}():" Uses "${FIRST["bin"]}()")"
      printf "%s" "${array} ${script}"  # Symbol icons have a new line
    fi
    set +xv
    echo
  done; echo

  for action in ${SORTED[actions]}; do
    ${action} "${action}()" "Adds the ':'"
  done; echo

  echo "## FUNCTIONS: helper.sh "
  export VAR1=1 VAR2=2
  DEBUG=1 debug VAR1 2>&1
  debug Debug Message: not shown "DEBUG unset" 2>&1
  DEBUG=1 debug VAR1 VAR2 2>&1
  DEBUG=1 QUIET=1 debug Not Shown: "QUIET=1" 2>&1
  DEBUG=1 debug 2>&1

  echo

  # TODO: Aqui lo dejo con el QUIET de los huevos.
  error Error Message 2>&1
  QUIET=1 error Not Shown: "QUIET=1" 2>&1
  error 2>&1

  echo

  success Success Message
  QUIET=1 success Not Shown: "QUIET=1"
  success

  echo

  VERBOSE=1 verbose Verbose Message: "VERBOSE=1"
  VERBOSE=1 QUIET=1 verbose Not Shown: "QUIET=1"
  VERBOSE=1 verbose

  echo

  WARNING=1 warning Warning Message: "WARNING=1" 2>&1
  WARNING=1 QUIET=1 warning Not shown: "QUIET=1" 2>&1
  WARNING=1 warning 2>&1

  echo

  die Die Message
}

#######################################
# actions
# Globals:
#   ACTIONS
#   BIN_DIR_TMP
#   file
#   header
#   if
#   symbol
# Arguments:
#  None
#######################################
save_bin_actions() {
  local i file symbol

  for i in "${!ACTIONS[@]}"; do
      symbol="${ACTIONS["${i}"]}"
      file="${TMP["bin"]}/${i}"
    cat >"${file}" <<EOF
#!/bin/sh

# <html><h2>${i}</h2>
# <h3>Examples</h3>
# <dl>
# <dt>
# Prefix output with ${symbol}, suffix output with ${i} in Normal format, and arguments in ${FIRST["format"]}:
# </dt>
# <dd>
# <pre><code class="language-bash">${i} Brew
# </code></pre>
# </dd>
# </dl>
# </html>
${symbol} "\$*:" "${i}"
EOF
    chmod +x "${file}"
  done
}

#######################################
# update colors in files and COLORS array
# Globals:
#   BIN_DIR_TMP
#   BUILD
#   ESCAPE
#   COLORS
#   LIB_PATH_TMP
# Arguments:
#   1   Color Variable Name
#   2   Color Value
#######################################
save_bin_colors() {
  local i file lower
  for i in ${SORTED["colors"]}; do
    lower="${i,,}"
    file="${TMP["bin"]}/${lower}"
    if [[ "${i}" =~ ${ESCAPED} ]]; then
      cat > "${file}" <<EOF
#!/bin/sh

# <html><h2>${lower}</h2>
# https://mywiki.wooledge.org/BashFAQ/053
# <a href="https://mywiki.wooledge.org/BashFAQ/053">Dynamic prompt or read -p</a>
# <h3>Examples</h3>
# <dl>
# <dt>Show arguments in Escaped ${i/${ESCAPED}/} for \$PS1 ,dynamic prompt or read -p:</dt>
# <dd>
# <pre><code class="language-bash">${lower} Show Text
# </code></pre>
# </dd>
# </dl>
# </html>
[ \$# -eq 0 ] || printf -- '%s' "${COLORS["${i}"]}" "\$*" "${COLORS["Normal${ESCAPED}"]}"
EOF
    else
      cat > "${file}" <<EOF
#!/bin/sh

# <html><h2>${lower}</h2>
# <h3>Examples</h3>
# <dl>
# <dt>Show arguments with space in ${i}:</dt>
# <dd>
# <pre><code class="language-bash">${lower} Show Text
# </code></pre>
# </dd>
# </dl>
# </html>
[ \$# -eq 0 ] || printf '%b' "${COLORS["${i}"]}"; printf '%b' "\$*"; printf '%b' "${COLORS[Normal]}"
EOF
    fi
    chmod +x "${file}"
  done
}

#######################################
# save executable to show first argument in italic
# Globals:
#   BIN_DIR_TMP
#   FIRST
# Arguments:
#  None
#######################################
save_bin_first() {
  local file format
  file="${TMP["bin"]}/${FIRST["bin"]}"
  format="${FIRST["format"]}"
  cat > "${file}" <<EOF
#!/bin/sh

# <html><h2>firstitalic</h2>
# <h3>Examples</h3>
# <dl>
# <dt>
# First Argument in ${format} and rest normal:
# </dt>
# <dd>
# <pre><code class="language-bash">${FIRST["bin"]} Show Text
# </code></pre>
# </dd>
# </dl>
# </html>

[ \$# -ne 0 ] || exit
first="\$1"; shift
[ \$# -eq 0 ] || sep=" "
printf "\$(${format,,} "\${first}")%s\n" "\${sep-}\$*"
EOF
    chmod +x "${file}"
}

#######################################
# add color symbols variables and executables
# Globals:
#   SYM_PATH_TMP
# Arguments:
#   None
#######################################
save_bin_symbols() {
  # TODO: aqui lo dejo - Habría que mirar que coño hago con verbose, error, y el stack.
  local file i symbol
  for i in ${SORTED["symbols"]}; do
    ! [[ "${i}" =~ ${ESCAPED} ]] || continue
    local condition="" header=""
    if [ "${i}" = 'Verbose' ]; then
      condition=' && { [ "${VERBOSE}" -eq 1 ] || [ "${DRY_RUN-}" -eq 1 ]; }'
      header="$(cat <<'EOF'
# <html><h2>Dry Run</h2>
# <p><strong><code>$DRY_RUN</code></strong> (Default: 0).</p>
# <p>Activate with either of:</p>
# <ul>
# <li><code>DRY_RUN=1</code></li>
# <li><code>--dryrun</code></li>
# </ul>
# </html>
DRY_RUN="${DRY_RUN:-0}"

# <html><h2>Show Verbose Messages</h2>
# <p><strong><code>$VERBOSE</code></strong> (Default: 0).</p>
# <p><strong><code>Verbose messages are shown if set to 1.</code></strong></p>
# <p>Activate with either of:</p>
# <ul>
# <li><code>VERBOSE=1</code></li>
# <li><code>--verbose</code></li>
# </ul>
# </html>
VERBOSE="${VERBOSE:-0}"
EOF
)"
    fi

    file="${TMP["bin"]}/${i}"
    symbol="$(printf '%b' "${SYMBOLS["${i}"]}")"
    cat >"${file}" <<EOF
#!/bin/sh
${header}
# <html><h2>${symbol}</h2>
# <h3>Examples</h3>
# <dl>
# <dt>
# Show arguments separated with space, prefixed with ${i} symbol. First argument in ${FIRST["format"]}, other Normal:
# </dt>
# <dd>
# <pre><code class="language-bash">${i} Show Text
# </code></pre>
# </dd>
# </dl>
# </html>

if [ "\${QUIET-0}" -ne 1 ]${condition}; then
  first="\$(${FIRST["bin"]} "\$@")"
  printf '%s' "${symbol}" "\${first:+ "\${first}"}"
  [ ! "\${first-}" ] || echo
fi
EOF
    chmod +x "${file}"
  done
}

#######################################
# update colors in files and COLORS array
# Globals:
#   BIN_DIR_TMP
#   BUILD
#   ESCAPE
#   COLORS
#   LIB_PATH_TMP
# Arguments:
#   1   Color Variable Name
#   2   Color Value
#######################################
save_lib_colors() {
  local i
  for i in ${SORTED["colors"]}; do
    tee -a "${TMP["lib"]}" > /dev/null <<EOF
# <html><h2>${i}</h2>
# <p><strong><code>\$${i}</code></strong> Color ${i}.</p>
# </html>
export ${i}="${COLORS["${i}"]}"

EOF
  done
}

#######################################
# save PS2 to profile lib
# Arguments:
#  None
#######################################
save_lib_ps2() {
  cat > "${TMP["ps2"]}" <<EOF
# shellcheck shell=sh

#
# PS2 Color library (generated by: ${_SCRIPT})

# PS2
#
export PS2="\\\$(if [ \\\$(id -u) -eq 0 ]; \
then printf -- '%s' '${COLORS["Magenta${ESCAPED}"]}' '> ' '${COLORS["Normal${ESCAPED}"]}'; \
else printf -- '%s' '${COLORS["Green${ESCAPED}"]}' '> ' '${COLORS["Normal${ESCAPED}"]}'; fi)"
EOF
}

#######################################
# add color symbols variables and executables
# Globals:
#   SYM_PATH_TMP
# Arguments:
#   None
#######################################
save_lib_symbols() {
  local i
  for i in ${SORTED["symbols"]}; do
    tee -a "${TMP["sym"]}" > /dev/null <<EOF
# <html><h2>${i}</h2>
# <p><strong><code>\$${i}</code></strong> Color ${i}.</p>
# </html>
export ${i}="${SYMBOLS["${i}"]}"

EOF
  done
}

#######################################
# sort colors array
# Globals:
#   COLORS
#   NAMES
# Arguments:
#   1
#######################################
sorted() {
  local regex
  regex="$(newline-to "$(printf "%s\n" "${NAMES[@]}")" '|')"
  printf "%s\n" "${!COLORS[@]}" | grep -vE "${regex}" | sort
  [ "${1-}" = 'white' ] || printf "%s\n" "${!COLORS[@]}" | grep -E "${regex}" | sort
}

#######################################
# show colors and helper functions output, or generate color lib
# Globals:
#   BIN_DIR
#   BUILD
#   FIRST
#   LIB_PATH
#   RC
#   RC_PROFILE_D
#   SCRIPT
#   SYM_PATH
# Arguments:
#  None
#######################################
main() {
  local arg func=demo i

  for arg do
    case "${arg}" in
      build) func="${arg}" ;;
      --*) fromman "$0" "$@" || exit 0 ;;
    esac
  done

  arrays

  for i in "${DST[@]}"; do
    [ -e "${i}" ] || { build; break; }
  done

  for i in "${DST[@]}"; do
    [ -d "${i}" ] || . "${i}"
  done

  ${func}
}

main "$@"
