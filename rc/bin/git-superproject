#!/bin/sh

: git rev-parse

script="$(greenbold "${0##*/}")"

OPTIONS_SPEC="$(cat <<EOF
${script}
${script} [$(magentabold "<path>")]

${script} - Super project repository path from file or directory in a submodule (default: $(magentabold "cwd"))
                   Empty if $(magentabold "<path>") in git repository but not on a submodule.

                   Error would be given if file/dir is in the submodule index but is not cloned:
                      .../git-dirname: line ..: cd: <path>: No such file or directory
--
h,help    Show help and exit.
EOF
)"

eval "$(echo "$OPTIONS_SPEC" | git rev-parse --parseopt -- "$@" || echo exit $?)"
shift

git ${1:+-C "$(git dirname "$1")"} rev-parse --show-superproject-working-tree
