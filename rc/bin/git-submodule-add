#!/bin/sh

: git submodule

# TODO: Aqui lo dejo sacar la default branch de remote y pasar los aliases y el git all
#   etc.
#   y el commands.

set -eu

script="$(greenbold "${0##*/}")"

OPTIONS_SPEC="$(cat <<EOF
${script} $(redbold "<url>") [$(redbold "<path>")]
${script} $(redbold "<url>")

${script} - Add submodule with name from $(redbold "<url>") basename \
(default: $(redbold "<name>")).
                    With default remote $(redbold "branch") and $(redbold "merge") update strategy.

                    Examples:
                      $ ${script} https://github.com/bats-core/bats-core $(greenbold '=>') $(redbold "bats-core")
                      $ ${script} https://github.com/bats-core/bats-core \
$(redbold "share/bats-core") $(greenbold '=>') $(redbold "share/bats-core")
--
h,help    Show help and exit.
EOF
)"

eval "$(echo "${OPTIONS_SPEC}" | git rev-parse --parseopt -- "$@" || echo exit $?)"
shift

name="$(basename "$1" .git)"
path="${2:-${name}}"


git submodule status "${name}" >/dev/null 2>&/dev/null || {
    git submodule add --quiet --name "${name}" --branch "$(git default "$1")" "$1" "${path}"

}
