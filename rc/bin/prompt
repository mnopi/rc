#!/bin/sh

main() {
  if [ "${1-}" ]; then
    if [ "$1" = "0" ]; then
      green "✔ "
    else
      red "$1 "
    fi

    [ ! "${HOST_PROMPT-}" ] || blue "${HOST_PROMPT} "

    # TODO: /Library/Developer/CommandLineTools/usr/share/git-core
    #   substituir por ... o directamente quitarle el /
    cyan "$(pwd | sed "s|${HOME}|~|" | tr '/' '\n' | tail -3 | sed -n "H;\${x;s|\n|/|g;s|^//|/|;s|^/~|~|;s|^~/||;p;}") "
    func=magenta
    [ "$(id -u)" -eq 0 ] || func=green
    ${func} "〉"
    exit "$1"
  fi
}

main "$@"
