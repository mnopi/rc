#!/bin/sh

main() {
  rc="$(($1))"

  printf -- "%s" "\[\e]0;\h@\u: \w\a\]"
  if [ "${rc}" -eq 0 ]; then
    greenesc "✔ "
  else
    redesc "$1 "
  fi

  # TODO: /Library/Developer/CommandLineTools/usr/share/git-core
  #   substituir por ... o directamente quitarle el /
  cyanesc "$(pwd | sed "s|${HOME}|~|" | tr '/' '\n' | tail -3 | \
    sed -n "H;\${x;s|\n|/|g;s|^//|/|;s|^/~|~|;s|^~/||;p;}") "

  [ ! "${HOST_PROMPT-}" ] || blueesc "${HOST_PROMPT} "
  [ "${PROMPT_SH}" = "1" ] || greyesc "${PROMPT_SH} "

  function="magentaesc"
  [ "$(id -u)" -eq 0 ] || function="greenesc"
  "${function}" "〉"
  exit $rc
}

main "$@"
