#!/bin/sh

main() {
  rc="$(($1))"
  esc="esc"

  case "${SH-}" in
    dash) esc=""; printf -- "%s" "\033]0;\h@\u: \w\a" ;;
    *) printf -- "%s" "\[\e]0;\h@\u: \w\a\]" ;;
  esac

  if [ "${rc}" -eq 0 ]; then
    "green${esc}" "✔ "
  else
    "red${esc}" "$1 "
  fi

  # TODO: /Library/Developer/CommandLineTools/usr/share/git-core
  #   substituir por ... o directamente quitarle el /
  "cyan${esc}" "$(pwd | sed "s|${HOME}|~|" | tr '/' '\n' | tail -3 \
    | sed -n "H;\${x;s|\n|/|g;s|^//|/|;s|^/~|~|;s|^~/||;p;}") "

  [ ! "${HOST_PROMPT-}" ] || "blue${esc}" "${HOST_PROMPT} "
  [ "${BASH4:-${SH}}" = "1" ] || [ ! "${SH-}" ] || "grey${_ESCAPED_PROMPT}" "${SH} "

  function="magenta"
  [ "$(id -u)" -eq 0 ] || function="green"
  "${function}${esc}" "〉"
  exit $rc
}

main "$@"
