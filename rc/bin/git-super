#!/bin/sh

: git rev-parse

script="$(green "${0##*/}")"

OPTIONS_SPEC="$(cat <<EOF
${script}
${script} [$(magentabold "<path>")]

${script} - Super project repository path from file or directory $(magentabold "<path>") in super project or submodule \
(default: $(magentabold "cwd"))
            Always show super project if $(magentabold "<path>") in git repository but not on a submodule.
--
h,help    Show help and exit.
EOF
)"

eval "$(echo "$OPTIONS_SPEC" | git rev-parse --parseopt -- "$@" || echo exit $?)"
shift

paths="$(git ${1:+-C "$(git dirname "$1")"} rev-parse --show-superproject-working-tree --show-toplevel)" \
  && echo "${paths}" | head -1
