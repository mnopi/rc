#!/bin/sh

: git rev-parse

#######################################
# git spec
# Globals:
#   SCRIPT
# Arguments:
#  None
#######################################
spec() {
  cat <<EOF
${SCRIPT}
${SCRIPT} [$(magenta "<path>")]

${SCRIPT} - super project repository path from file or directory $(magenta "<path>") in super project or submodule \
(default: $(magenta "cwd"))
            Always show super project if $(magenta "<path>") in git repository but not on a submodule.
--
h,help    Show help and exit.
EOF
}

#######################################
# git super project repository path
# Arguments:
#  [<path>]     path (default: cwd)
#######################################
main() {
  paths="$(git ${1:+-C "$(git dirname "$1")"} rev-parse --show-superproject-working-tree --show-toplevel)" \
  && echo "${paths}" | head -1
}

. git-parse.sh; shift
main "$@"
