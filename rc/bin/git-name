#!/bin/sh

: git config

#######################################
# basename
# Arguments:
#  path
#######################################
base() { basename -- "$1" .git; exit; }

#######################################
# git spec
# Globals:
#   SCRIPT
# Arguments:
#  None
#######################################
spec() {
  cat <<EOF
${SCRIPT}
${SCRIPT} [$(magenta "<remote>")|$(magenta "<url>")]
${SCRIPT} $(magenta "<remote>")
${SCRIPT} $(magenta "<url>")
${SCRIPT} - repository name from config remote url or url (default: $(magenta "origin"))
--
h,help    Show help and exit.
EOF
}

#######################################
# git repository name
# Arguments:
#  [<remote>|<url>]     remote name or url (default: cwd)
#######################################
main() {
  if [ "${1-}" ] && echo "${1-}" | grep -q '/'; then
    base "$(echo "$1" | sed 's|https://raw.githubusercontent.com/||g')"
  else
    url="$(git url "${1-}")" && base "${url}"
  fi
}

. git-parse.sh; shift
main "$@"
