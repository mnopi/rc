#!/bin/sh

: git config

script="$(green "${0##*/}")"

OPTIONS_SPEC="$(cat <<EOF
${script}
${script} [$(magentabold "<remote>")]

${script} - Repository name from config remote url (default: $(magentabold "origin"))
--
h,help    Show help and exit.
EOF
)"

eval "$(echo "$OPTIONS_SPEC" | git rev-parse --parseopt -- "$@" || echo exit $?)"
shift

url="$(git url "${1-}")" && basename "${url}" .git
