#!/bin/sh

: git rev-parse

#######################################
# git spec
# Globals:
#   SCRIPT
# Arguments:
#  None
#######################################
spec() {
  cat <<EOF
${SCRIPT}
${SCRIPT} $(magentabold "<path>")

${SCRIPT} - is git repository $(magentabold "<path>") \
--
h,help    Show help and exit.
EOF
}

#######################################
# is git repository
# Arguments:
#  [<path>]     path (default: cwd)
#######################################
main() { git ${1:+-C "$(git dirname "$1")"} top  >/dev/null 2>&1; }

. git-parse.sh; shift
main "$@"
