#!/bin/sh

#######################################
# git spec
# Globals:
#   SCRIPT
# Arguments:
#  None
#######################################
spec() {
  cat <<EOF
${SCRIPT}
${SCRIPT} $(magenta "<user>")

${SCRIPT} - Check SSH access to GitHub (default: $(magenta "\$USER"))
--
h,help    Show help and exit.
EOF
}

#######################################
# git ssh access
# Arguments:
#  [<user>|<url>]  remote name or url (default: $USER).
#######################################
main() { ssh -T git@github.com 2>&1 | grep -q "Hi ${1:-${USER}}\!"; }

. git-parse.sh; shift
main "$@"


