#!/bin/sh

: git config

script="$(green "${0##*/}")"

OPTIONS_SPEC="$(cat <<EOF
${script}
${script} [$(magentabold "<remote>")]

${script} - Remote url from config (default: $(magentabold "origin"))
--
h,help    Show help and exit.
EOF
)"

eval "$(echo "$OPTIONS_SPEC" | git rev-parse --parseopt -- "$@" || echo exit $?)"
shift

git config remote."${1:-origin}".url
