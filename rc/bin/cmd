#!/bin/sh

set -eu

#######################################
# command or commands exists
# Arguments:
#  command [command]    command or commands
# Returns:
#  1 if any of the command does not exist
#######################################
main() {
  if [ $# -eq 1 ]; then
    type "$1" >/dev/null 2>&1
  else
    tmp="$(mktemp)"
    type "$@" >/dev/null 2>"${tmp}"
    grep -qv "not found" "${tmp}"
  fi
}

## Error
# cmd foo
# cmd ls foo cd
