#!/bin/sh

# <html><h2>[1;36m…[0m</h2>
# <h3>Examples</h3>
# <dl>
# <dt>
# Show arguments separated with space, prefixed with Ellipsis symbol. First argument in Bold,
# other Italic:
# </dt>
# <dd>
# <pre><code class="language-bash">Ellipsis Show Text
# </code></pre>
# </dd>
# </dl>
# </html>

if [ "${QUIET-0}" -ne 1 ]; then
  first="$(FirstOther "$@")"
  printf '%b' "[1;36m…[0m" "${first:+ "\e[1;36m${first}\e[0m"}"
  [ ! "${first-}" ] || echo
fi
