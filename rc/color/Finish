#!/bin/sh

# <html><h2>Finish</h2>
# <h3>Examples</h3>
# <dl>
# <dt>
# Show arguments separated with space and prefixed with Finish. If more than one arguments then first in Italic:
# </dt>
# <dd>
# <pre><code class="language-bash">Finish Show Text
# </code></pre>
# </dd>
# </dl>
# </html>
ret=$?

if { [ "${QUIET-0}" -ne 1 ] && [ "${QQUIET-0}" -ne 1 ];}; then
  [ $# -ne 0 ] || exit $ret
  printf '%b' "\e[1;32m=>\e[0m"
  [ $# -eq 1 ] || italic "$1 "
  printf '%s\n' "$*"
fi

exit $ret
