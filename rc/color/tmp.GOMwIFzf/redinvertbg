#!/bin/sh

# <html><h2>redinvertbg</h2>
# <h3>Examples</h3>
# <dl>
# <dt>Show arguments with space in RedInvertBg:</dt>
# <dd>
# <pre><code class="language-bash">redinvertbg Show Text
# </code></pre>
# </dd>
# </dl>
# </html>
[ $# -eq 0 ] || printf '%b' "\e[7;41m"; printf '%b' "$*"; printf '%b' "\e[0m"
