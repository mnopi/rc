#!/bin/sh

# <html><h2>[1;34m～[0m</h2>
# <h3>Examples</h3>
# <dl>
# <dt>
# Show arguments separated with space, prefixed with Tilde symbol. First argument in Bold,
# other Italic:
# </dt>
# <dd>
# <pre><code class="language-bash">Tilde Show Text
# </code></pre>
# </dd>
# </dl>
# </html>

if [ "${QUIET-0}" -ne 1 ]; then
  first="$(FirstOther "$@\e[0m")"
  printf '%s' "[1;34m～[0m" "${first:+ "${first}"}"
  [ ! "${first-}" ] || echo
fi
