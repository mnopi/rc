#!/bin/sh

# <html><h2>greenbolditalicesc</h2>
# https://mywiki.wooledge.org/BashFAQ/053
# <a href="https://mywiki.wooledge.org/BashFAQ/053">Dynamic prompt or read -p</a>
# <h3>Examples</h3>
# <dl>
# <dt>Show arguments in Escaped GreenBoldItalic for $PS1 ,dynamic prompt or read -p:</dt>
# <dd>
# <pre><code class="language-bash">greenbolditalicesc Show Text
# </code></pre>
# </dd>
# </dl>
# </html>
[ $# -eq 0 ] || printf -- '%s' "\[\e[3m\e[1;32m\]" "$*" "\[\e[0m\]"
