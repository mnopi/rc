#!/bin/sh

# <html><h2>yellowdimbg</h2>
# <h3>Examples</h3>
# <dl>
# <dt>Show arguments with space in YellowDimBg:</dt>
# <dd>
# <pre><code class="language-bash">yellowdimbg Show Text
# </code></pre>
# </dd>
# </dl>
# </html>
[ $# -eq 0 ] || printf '%b' "\e[2;43m"; printf '%b' "$*"; printf '%b' "\e[0m"
